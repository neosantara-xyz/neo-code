{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": [
				"./*"
			],
			"@neosantara-xyz/ai": [
				"./packages/ai/src/index.ts"
			],
			"@neosantara-xyz/ai/oauth": [
				"./packages/ai/src/oauth.ts"
			],
			"@neosantara-xyz/ai/*": [
				"./packages/ai/src/*.ts",
				"./packages/ai/src/providers/*.ts"
			],
			"@neosantara-xyz/ai/dist/*": [
				"./packages/ai/src/*"
			],
			"@neosantara-xyz/agent-core": [
				"./packages/agent/src/index.ts"
			],
			"@neosantara-xyz/agent-core/*": [
				"./packages/agent/src/*"
			],
			"@neosantara-xyz/code": [
				"./packages/coding-agent/src/index.ts"
			],
			"@neosantara-xyz/code/hooks": [
				"./packages/coding-agent/src/core/hooks/index.ts"
			],
			"@neosantara-xyz/code/*": [
				"./packages/coding-agent/src/*"
			],
			"typebox": [
				"./node_modules/typebox"
			],
			"@neosantara-xyz/tui": [
				"./packages/tui/src/index.ts"
			],
			"@neosantara-xyz/tui/*": [
				"./packages/tui/src/*"
			],
			"@neosantara-xyz/agent-old": [
				"./packages/agent-old/src/index.ts"
			],
			"@neosantara-xyz/agent-old/*": [
				"./packages/agent-old/src/*"
			]
		}
	},
	"include": [
		"packages/*/src/**/*"
	],
	"exclude": [
		"**/dist/**",
		"node_modules",
		"packages/web/**"
	]
}
