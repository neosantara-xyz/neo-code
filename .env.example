# Neosantara API credentials. Server-side only — never expose to a browser.
NEOSANTARA_API_KEY=

# Auth API base URL for `neo login` device flow. Either name works; the
# NEO_CODE_-prefixed variant is preferred when running inside the CLI.
NEOSANTARA_API_BASE_URL=https://api.neosantara.xyz
NEO_CODE_NEOSANTARA_API_BASE_URL=

# Coding-agent runtime flags.
# Override the agent config dir (default: ~/.neo-code/agent).
NEO_CODE_CODING_AGENT_DIR=
# Override the session storage dir (default: <agent-dir>/sessions).
NEO_CODE_CODING_AGENT_SESSION_DIR=
# Override the package directory (useful for Nix/Guix store paths).
NEO_CODE_PACKAGE_DIR=
# Base URL for the /share command (default: https://app.neosantara.xyz/session/).
NEO_CODE_SHARE_VIEWER_URL=
# Disable startup network operations (1/true/yes). Same as `--offline`.
NEO_CODE_OFFLINE=
# Skip the startup version check.
NEO_CODE_SKIP_VERSION_CHECK=
# Override install telemetry (1/true/yes to enable, 0/false/no to disable).
NEO_CODE_TELEMETRY=
# Use the longer "24h" prompt cache retention where supported.
NEO_CODE_CACHE_RETENTION=
# Force a startup benchmark output (interactive mode only).
NEO_CODE_STARTUP_BENCHMARK=

# TUI debug flags.
NEO_CODE_HARDWARE_CURSOR=
NEO_CODE_CLEAR_ON_SHRINK=
NEO_CODE_DEBUG_REDRAW=
NEO_CODE_TUI_DEBUG=
